{
    "name": "d-opensubdiv",
    "description": "D bindings for a thin C shim around Pixar's OpenSubdiv 3.x — Catmull-Clark stencil evaluation on the CPU.",
    "license": "Apache-2.0",
    "authors": ["Alexander Shagarov"],

    "targetType": "staticLibrary",

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-osx": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --recursive --quiet",
        "xcrun -sdk macosx cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target osdc"
    ],
    "preBuildCommands-linux": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --recursive --quiet",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target osdc"
    ],
    "preBuildCommands-windows": [
        "cd /d \"$PACKAGE_DIR\" && git submodule update --init --recursive --quiet",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" --config Release --target osdc"
    ],

    "lflags-posix": [
        "-L$PACKAGE_DIR/build",
        "-L$PACKAGE_DIR/build/extern/OpenSubdiv/opensubdiv"
    ],
    "lflags-windows": [
        "/LIBPATH:$PACKAGE_DIR/build/Release",
        "$PACKAGE_DIR/build/extern/OpenSubdiv/opensubdiv/Release/osdCPU.lib",
        "$PACKAGE_DIR/build/extern/OpenSubdiv/opensubdiv/Release/osdGPU.lib"
    ],

    "libs-linux":   ["osdc", "osdCPU", "osdGPU", "GL", "stdc++", "m"],
    "libs-osx":     ["osdc", "osdCPU", "osdGPU", "c++", "m"],
    "libs-windows": ["osdc", "opengl32"],
    "frameworks":   ["OpenGL"]
}
